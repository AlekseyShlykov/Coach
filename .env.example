# MailerLite API key (get it from: MailerLite → Integrations → API)
MAILERLITE_API_KEY=your_api_key_here

# MailerLite group ID for free subscribers
# To find it: MailerLite → Subscribers → Groups → click the group → the ID is in the URL
MAILERLITE_GROUP_ID=your_group_id_here

# Server port (optional, defaults to 3000)
PORT=3000
